{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.n24q02m/better-code-review-graph",
  "description": "Knowledge graph for token-efficient code reviews with fixed search and configurable embeddings",
  "repository": {
    "url": "https://github.com/n24q02m/better-code-review-graph",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "name": "better-code-review-graph",
      "version": "0.1.0",
      "runtimeHint": "uvx",
      "runtimeArgs": ["--python", "3.13", "better-code-review-graph", "serve"]
    },
    {
      "registryType": "oci",
      "name": "n24q02m/better-code-review-graph",
      "version": "0.1.0",
      "runtimeHint": "docker",
      "runtimeArgs": ["run", "-i", "--rm", "n24q02m/better-code-review-graph"]
    }
  ]
}
